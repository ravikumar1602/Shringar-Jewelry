# Copy this file to .env and update with your local IP
# To find your local IP: Run 'ipconfig' (Windows) or 'ifconfig' (Mac/Linux)
# Look for IPv4 Address under your active network adapter (Wi-Fi)

# For Android Emulator: API_URL=http://10.0.2.2:5000/api/v1
# For Real Device on same WiFi: API_URL=http://YOUR_LOCAL_IP:5000/api/v1
# For iOS Simulator: API_URL=http://localhost:5000/api/v1
# For Production: API_URL=https://your-backend.render.com/api/v1

API_URL=http://192.168.1.6:5000/api/v1
